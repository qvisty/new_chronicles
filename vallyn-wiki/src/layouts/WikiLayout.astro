---
export interface Props {
  title: string;
  description?: string;
  section?: string;
}

const { title, description = 'The world of Vallyn - a living wiki', section = '' } = Astro.props;
const pageTitle = title === 'Vallyn Wiki' ? title : `${title} | Vallyn Wiki`;
const base = import.meta.env.BASE_URL; // e.g. "/new_chronicles/"
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>
  <link rel="icon" href={`${base}favicon.ico`} />
  <!-- Pagefind UI -->
  <link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />
</head>
<body class="min-h-screen bg-parchment-50 text-ink-900 font-sans">

  <!-- Top bar -->
  <header class="sticky top-0 z-50 bg-parchment-900 text-parchment-100 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between gap-4">
      <a href={base} class="flex items-center gap-2 font-serif text-xl font-bold text-parchment-100 hover:text-parchment-300 transition-colors whitespace-nowrap">
        &#9768; Vallyn Wiki
      </a>
      <!-- Pagefind search -->
      <div id="search" class="flex-1 max-w-md"></div>
      <nav class="hidden md:flex items-center gap-4 text-sm font-medium">
        <a href={base} class="hover:text-parchment-300 transition-colors">Home</a>
        <a href={`${base}wiki/Vallyn`} class="hover:text-parchment-300 transition-colors">World</a>
        <a href={`${base}wiki/People`} class="hover:text-parchment-300 transition-colors">People</a>
      </nav>
    </div>
  </header>

  <!-- Breadcrumb / section label -->
  {section && (
    <div class="bg-parchment-100 border-b border-parchment-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 text-sm text-parchment-700">
        <a href={base} class="hover:underline">Home</a>
        <span class="mx-2">/</span>
        <span>{section}</span>
      </div>
    </div>
  )}

  <!-- Main content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <slot />
  </main>

  <footer class="mt-16 border-t border-parchment-200 bg-parchment-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 text-sm text-parchment-600 text-center">
      Vallyn Wiki &mdash; The world of New Chronicles
    </div>
  </footer>

  <script define:vars={{ pagefindBase: base }}>
    const script = document.createElement('script');
    script.src = pagefindBase + 'pagefind/pagefind-ui.js';
    script.onload = function() {
      new window.PagefindUI({
        element: '#search',
        showSubResults: false,
        showImages: false,
        resetStyles: false,
      });
    };
    document.head.appendChild(script);
  </script>

</body>
</html>

<style is:global>
  html { scroll-behavior: smooth; }
  /* Pagefind overrides to match parchment theme */
  .pagefind-ui {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: #85511a;
    --pagefind-ui-text: #1c1a14;
    --pagefind-ui-background: #fdf8f0;
    --pagefind-ui-border: #e9c27e;
    --pagefind-ui-tag: #f9eedb;
  }
  /* Prose styling for wiki content */
  .wiki-content {
    @apply prose prose-stone max-w-none;
  }
  .wiki-content h1, .wiki-content h2, .wiki-content h3 {
    @apply font-serif;
  }
  .wiki-content a {
    @apply text-parchment-700 underline hover:text-parchment-500;
  }
</style>
