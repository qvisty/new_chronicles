---
export interface Props {
  title: string;
  description?: string;
  section?: string;
  campaignTheme?: 'chains' | 'dawn' | 'hub';
}

const {
  title,
  description = 'The world of Vallyn - a living wiki',
  section = '',
  campaignTheme = 'hub',
} = Astro.props;
const pageTitle = title === 'Vallyn Wiki' ? title : `${title} | Vallyn Wiki`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>
  <link rel="icon" href={`${base}/favicon.ico`} />
  <link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
</head>
<body class={`min-h-screen bg-chronicle-bg text-chronicle-text font-sans theme-${campaignTheme}`}>

  <!-- Navigation -->
  <header class="sticky top-0 z-50 border-b border-chronicle-border backdrop-blur-md bg-chronicle-bg/95">
    <div class="max-w-[1100px] mx-auto px-6 h-14 flex items-center justify-between gap-6">
      <a href={`${base}/`} class="flex items-center gap-2 font-serif text-lg text-accent-light hover:opacity-80 transition-opacity whitespace-nowrap">
        The Chronicles
      </a>
      <div id="search" class="flex-1 max-w-md"></div>
      <nav class="hidden md:flex items-center gap-6 text-sm">
        <a href={`${base}/`} class="text-chronicle-muted hover:text-chronicle-text transition-colors">Home</a>
        <a href={`${base}/wiki/Vallyn`} class="text-chronicle-muted hover:text-chronicle-text transition-colors">World</a>
        <a href={`${base}/wiki/People`} class="text-chronicle-muted hover:text-chronicle-text transition-colors">People</a>
      </nav>
    </div>
  </header>

  <!-- Breadcrumb -->
  {section && (
    <div class="border-b border-chronicle-border">
      <div class="max-w-[1100px] mx-auto px-6 py-2 text-sm text-chronicle-muted">
        <a href={`${base}/`} class="hover:text-chronicle-text transition-colors">Home</a>
        <span class="mx-2 text-chronicle-dim">/</span>
        <span class="text-chronicle-muted">{section}</span>
      </div>
    </div>
  )}

  <!-- Main content -->
  <main class="max-w-[1100px] mx-auto px-6 py-10">
    <slot />
  </main>

  <footer class="border-t border-chronicle-border mt-16">
    <div class="max-w-[1100px] mx-auto px-6 py-8 text-sm text-chronicle-muted text-center">
      The Chronicles &mdash; a collection of tabletop stories set in the world of Vallyn
    </div>
  </footer>

  <script define:vars={{ pagefindBase: base }}>
    const script = document.createElement('script');
    script.src = pagefindBase + '/pagefind/pagefind-ui.js';
    script.onload = function() {
      new window.PagefindUI({
        element: '#search',
        showSubResults: false,
        showImages: false,
        resetStyles: false,
      });
    };
    document.head.appendChild(script);
  </script>

</body>
</html>

<style is:global>
  html { scroll-behavior: smooth; }

  /* Pagefind overrides for dark theme */
  .pagefind-ui {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: #8a90b8;
    --pagefind-ui-text: #ddd4bb;
    --pagefind-ui-background: #14141e;
    --pagefind-ui-border: #2a2a38;
    --pagefind-ui-tag: #1c1c28;
  }

  /* Campaign theme accent overrides */
  .theme-chains {
    --accent-color: #9b2626;
    --accent-light: #c43c3c;
  }
  .theme-dawn {
    --accent-color: #c9a227;
    --accent-light: #e8bc30;
  }
  .theme-hub {
    --accent-color: #6a7090;
    --accent-light: #8a90b8;
  }

  /* Prose styling for wiki content (dark theme) */
  .wiki-prose {
    @apply prose prose-invert max-w-none;
    --tw-prose-body: #ddd4bb;
    --tw-prose-headings: #ddd4bb;
    --tw-prose-links: #8a90b8;
    --tw-prose-bold: #ddd4bb;
    --tw-prose-counters: #8a8070;
    --tw-prose-bullets: #8a8070;
    --tw-prose-hr: #2a2a38;
    --tw-prose-quotes: #8a8070;
    --tw-prose-quote-borders: #2a2a38;
    --tw-prose-code: #ddd4bb;
    --tw-prose-pre-code: #ddd4bb;
    --tw-prose-pre-bg: #14141e;
    --tw-prose-th-borders: #2a2a38;
    --tw-prose-td-borders: #2a2a38;
  }
  .wiki-prose h1, .wiki-prose h2, .wiki-prose h3, .wiki-prose h4 {
    @apply font-serif font-normal;
    letter-spacing: 0.01em;
  }
  .wiki-prose a {
    color: var(--accent-light, #8a90b8);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .wiki-prose a:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
  .wiki-prose blockquote {
    border-left-color: var(--accent-color, #6a7090);
    background: rgba(106, 112, 144, 0.08);
    border-radius: 0 6px 6px 0;
    padding: 1rem 1.5rem;
    font-family: Georgia, serif;
    font-style: italic;
  }

  /* Missing wiki link styling */
  .wiki-missing {
    color: #8a8070 !important;
    font-style: italic;
    cursor: help;
  }
</style>
