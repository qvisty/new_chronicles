---
export interface Props {
  title: string;
  description?: string;
  section?: string;
  campaignTheme?: 'chains' | 'dawn' | 'hub';
}

const {
  title,
  description = 'The world of Vallyn - a living wiki',
  section = '',
  campaignTheme = 'hub',
} = Astro.props;
const pageTitle = title === 'Vallyn Wiki' ? title : `${title} | Vallyn Wiki`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>
  <link rel="icon" href={`${base}/favicon.ico`} />
  <!-- Inter font (Catalyst design system) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
</head>
<body class={`min-h-screen bg-chronicle-bg text-chronicle-text font-sans theme-${campaignTheme}`}>

  <!-- Navigation (Catalyst-style fixed nav with backdrop blur) -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-chronicle-bg/80 backdrop-blur-xl border-b border-chronicle-border" role="navigation" aria-label="Main navigation">
    <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between gap-6">
      <!-- Logo -->
      <a href={`${base}/`} class="flex items-center gap-2.5 group" aria-label="The Chronicles Home">
        <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-acid text-chronicle-bg">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4">
            <path d="M3 8L7 4L13 8L7 12L3 8Z" fill="currentColor"/>
          </svg>
        </span>
        <span class="text-[15px] font-semibold tracking-[-0.02em] text-chronicle-text group-hover:text-acid transition-colors duration-200">The Chronicles</span>
      </a>

      <!-- Search (center) -->
      <div id="search" class="flex-1 max-w-md"></div>

      <!-- Nav links -->
      <div class="hidden md:flex items-center gap-1">
        <a href={`${base}/`} class="px-3 py-1.5 text-sm text-chronicle-muted hover:text-chronicle-text transition-colors duration-200 rounded-lg hover:bg-chronicle-raised">Home</a>
        <a href={`${base}/wiki/Vallyn`} class="px-3 py-1.5 text-sm text-chronicle-muted hover:text-chronicle-text transition-colors duration-200 rounded-lg hover:bg-chronicle-raised">World</a>
        <a href={`${base}/wiki/People`} class="px-3 py-1.5 text-sm text-chronicle-muted hover:text-chronicle-text transition-colors duration-200 rounded-lg hover:bg-chronicle-raised">People</a>
      </div>

      <!-- Mobile toggle -->
      <button class="md:hidden flex flex-col gap-1.5 p-2" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
        <span class="block w-5 h-0.5 bg-chronicle-text transition-all duration-200 origin-center" id="navLine1"></span>
        <span class="block w-5 h-0.5 bg-chronicle-text transition-all duration-200" id="navLine2"></span>
        <span class="block w-5 h-0.5 bg-chronicle-text transition-all duration-200 origin-center" id="navLine3"></span>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobileMenu" class="hidden md:hidden border-t border-chronicle-border bg-chronicle-bg/95 backdrop-blur-xl">
      <div class="max-w-[1200px] mx-auto px-6 py-4 flex flex-col gap-1">
        <a href={`${base}/`} class="px-3 py-2.5 text-sm text-chronicle-muted hover:text-chronicle-text rounded-lg hover:bg-chronicle-raised transition-colors">Home</a>
        <a href={`${base}/wiki/Vallyn`} class="px-3 py-2.5 text-sm text-chronicle-muted hover:text-chronicle-text rounded-lg hover:bg-chronicle-raised transition-colors">World</a>
        <a href={`${base}/wiki/People`} class="px-3 py-2.5 text-sm text-chronicle-muted hover:text-chronicle-text rounded-lg hover:bg-chronicle-raised transition-colors">People</a>
      </div>
    </div>
  </nav>

  <!-- Spacer for fixed nav -->
  <div class="h-16"></div>

  <!-- Breadcrumb -->
  {section && (
    <div class="border-b border-chronicle-border">
      <div class="max-w-[1200px] mx-auto px-6 py-2.5 text-sm text-chronicle-muted">
        <a href={`${base}/`} class="hover:text-chronicle-text transition-colors">Home</a>
        <span class="mx-2 text-chronicle-dim">/</span>
        <span class="text-chronicle-muted">{section}</span>
      </div>
    </div>
  )}

  <!-- Main content -->
  <main class="max-w-[1200px] mx-auto px-6 py-10">
    <slot />
  </main>

  <!-- Footer (Catalyst-style) -->
  <footer class="border-t border-chronicle-border mt-16">
    <div class="max-w-[1200px] mx-auto px-6 py-10">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2.5">
          <span class="flex items-center justify-center w-6 h-6 rounded-md bg-acid/20 text-acid">
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-3 h-3">
              <path d="M3 8L7 4L13 8L7 12L3 8Z" fill="currentColor"/>
            </svg>
          </span>
          <span class="text-sm font-medium text-chronicle-dim tracking-[-0.02em]">The Chronicles</span>
        </div>
        <p class="text-sm text-chronicle-dim">
          A collection of tabletop stories set in the world of Vallyn
        </p>
      </div>
    </div>
  </footer>

  <!-- Pagefind -->
  <script define:vars={{ pagefindBase: base }}>
    const script = document.createElement('script');
    script.src = pagefindBase + '/pagefind/pagefind-ui.js';
    script.onload = function() {
      new window.PagefindUI({
        element: '#search',
        showSubResults: false,
        showImages: false,
        resetStyles: false,
      });
    };
    document.head.appendChild(script);
  </script>

  <!-- Mobile nav toggle -->
  <script>
    const toggle = document.getElementById('navToggle');
    const menu = document.getElementById('mobileMenu');
    const line1 = document.getElementById('navLine1');
    const line2 = document.getElementById('navLine2');
    const line3 = document.getElementById('navLine3');

    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.contains('hidden') === false;
      if (isOpen) {
        menu?.classList.add('hidden');
        line1?.style.setProperty('transform', 'none');
        line2?.style.setProperty('opacity', '1');
        line3?.style.setProperty('transform', 'none');
        toggle?.setAttribute('aria-expanded', 'false');
      } else {
        menu?.classList.remove('hidden');
        line1?.style.setProperty('transform', 'rotate(45deg) translate(3px, 3px)');
        line2?.style.setProperty('opacity', '0');
        line3?.style.setProperty('transform', 'rotate(-45deg) translate(3px, -3px)');
        toggle?.setAttribute('aria-expanded', 'true');
      }
    });

    // Close on link click
    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });
  </script>

  <!-- Scroll reveal (Catalyst-style) -->
  <script>
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            entry.target.style.transitionDelay = `${i * 60}ms`;
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      reveals.forEach(el => observer.observe(el));
      setTimeout(() => { reveals.forEach(el => el.classList.add('visible')); }, 3000);
    } else {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
    }
  </script>

</body>
</html>

<style is:global>
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  body { letter-spacing: -0.02em; line-height: 1.6; overflow-x: hidden; }

  /* Scroll reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Catalyst card system (dark variant) */
  .catalyst-card {
    background: #111118;
    border: 1px solid #252530;
    border-radius: 16px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                border-color 0.25s ease;
  }
  .catalyst-card:hover {
    transform: translateY(-2px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 8px 30px rgba(0,0,0,0.3);
    border-color: #353540;
  }

  /* Catalyst acid button */
  .btn-acid {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 28px;
    background: #C8E600;
    color: #0a0a0f;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.02em;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.2s cubic-bezier(0.22, 1, 0.36, 1);
    text-decoration: none;
  }
  .btn-acid:hover {
    transform: translateY(-2px);
    box-shadow: 4px 4px 0px #e8e4dc;
  }
  .btn-acid:active {
    transform: translateY(0);
    box-shadow: 1px 1px 0px #e8e4dc;
  }

  /* Ghost button */
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 28px;
    background: transparent;
    color: #e8e4dc;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.02em;
    border: 1px solid #252530;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.2s cubic-bezier(0.22, 1, 0.36, 1),
                border-color 0.2s ease;
    text-decoration: none;
  }
  .btn-ghost:hover {
    transform: translateY(-2px);
    box-shadow: 4px 4px 0px rgba(200,230,0,0.2);
    border-color: #C8E600;
    color: #C8E600;
  }

  /* Pagefind overrides for dark Catalyst theme */
  .pagefind-ui {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: #C8E600;
    --pagefind-ui-text: #e8e4dc;
    --pagefind-ui-background: #111118;
    --pagefind-ui-border: #252530;
    --pagefind-ui-tag: #1a1a24;
  }

  /* Campaign theme accent overrides */
  .theme-chains {
    --accent-color: #9b2626;
    --accent-light: #c43c3c;
  }
  .theme-dawn {
    --accent-color: #c9a227;
    --accent-light: #e8bc30;
  }
  .theme-hub {
    --accent-color: #6a7090;
    --accent-light: #8a90b8;
  }

  /* Prose styling for wiki content (dark Catalyst theme) */
  .wiki-prose {
    @apply prose prose-invert max-w-none;
    --tw-prose-body: #e8e4dc;
    --tw-prose-headings: #e8e4dc;
    --tw-prose-links: #C8E600;
    --tw-prose-bold: #e8e4dc;
    --tw-prose-counters: #8a8070;
    --tw-prose-bullets: #8a8070;
    --tw-prose-hr: #252530;
    --tw-prose-quotes: #8a8070;
    --tw-prose-quote-borders: #252530;
    --tw-prose-code: #e8e4dc;
    --tw-prose-pre-code: #e8e4dc;
    --tw-prose-pre-bg: #111118;
    --tw-prose-th-borders: #252530;
    --tw-prose-td-borders: #252530;
  }
  .wiki-prose h1, .wiki-prose h2, .wiki-prose h3, .wiki-prose h4 {
    @apply font-serif font-normal;
    letter-spacing: 0.01em;
  }
  .wiki-prose a {
    color: var(--accent-light, #C8E600);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .wiki-prose a:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
  .wiki-prose blockquote {
    border-left-color: var(--accent-color, #6a7090);
    background: rgba(106, 112, 144, 0.08);
    border-radius: 0 6px 6px 0;
    padding: 1rem 1.5rem;
    font-family: Georgia, serif;
    font-style: italic;
  }

  /* Missing wiki link styling */
  .wiki-missing {
    color: #5a5650 !important;
    font-style: italic;
    cursor: help;
  }
</style>
