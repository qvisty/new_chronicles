---
import { getCollection, render } from 'astro:content';
import WikiLayout from '../../layouts/WikiLayout.astro';

// Format a raw filename into a readable display label
function formatFileName(rawName: string): string {
  // Remove .md extension
  let name = rawName.replace(/\.md$/, '');
  // Convert "Session -10_ Title" or "Session -10.5_ Title" to "Session 10: Title"
  name = name.replace(/^Session -(\d+(?:\.\d+)?)_\s*/, 'Session $1: ');
  // Convert remaining underscores to spaces
  name = name.replace(/_/g, ' ');
  return name;
}

export async function getStaticPaths() {
  function formatFileNameInner(rawName: string): string {
    let name = rawName.replace(/\.md$/, '');
    name = name.replace(/^Session -(\d+(?:\.\d+)?)_\s*/, 'Session $1: ');
    name = name.replace(/_/g, ' ');
    return name;
  }

  const allEntries = await getCollection('wiki');

  // Byg en map: lowercase filnavn -> slug (til opslag af related-links)
  const nameToSlug = new Map<string, string>();
  // Byg en map: foraeldre-sti -> liste af alle slugs i den mappe
  const folderToSlugs = new Map<string, string[]>();

  for (const entry of allEntries) {
    const slug = entry.id.replace(/\.md$/, '');
    const parts = slug.split('/');
    const name = parts[parts.length - 1];
    nameToSlug.set(name.toLowerCase(), slug);

    // Gruppeer efter foraeldre-mappe (alt undtagen filnavnet)
    const parentPath = parts.slice(0, -1).join('/');
    if (!folderToSlugs.has(parentPath)) folderToSlugs.set(parentPath, []);
    folderToSlugs.get(parentPath)!.push(slug);
  }

  const paths = [];

  for (const entry of allEntries) {
    // entry.id is the path within content/wiki/, e.g. "Chains of the Ancients/Stories/foo.md"
    const slug = entry.id.replace(/\.md$/, '');
    const parts = slug.split('/');
    const section = parts[0];
    const title = parts[parts.length - 1];

    // Resolv 'related' frontmatter til { label, href } objekter
    const relatedNames: string[] = (entry.data as any)?.related ?? [];
    const relatedLinks = relatedNames
      .map((name: string) => {
        const resolvedSlug = nameToSlug.get(name.toLowerCase());
        if (!resolvedSlug) return null;
        return {
          label: name,
          href: '/wiki/' + resolvedSlug.split('/').map(encodeURIComponent).join('/'),
        };
      })
      .filter(Boolean) as { label: string; href: string }[];

    // Automatiske nabosider: andre sider i samme mappe (maks 8)
    const parentPath = parts.slice(0, -1).join('/');
    const siblings = (folderToSlugs.get(parentPath) ?? [])
      .filter((s) => s !== slug)
      .slice(0, 8)
      .map((s) => ({
        label: formatFileNameInner(s.split('/').pop() || s),
        href: '/wiki/' + s.split('/').map(encodeURIComponent).join('/'),
      }));

    paths.push({
      // params.slug must be the raw path — Astro handles URL encoding automatically
      params: { slug },
      props: { entry, title, section, parts, isSection: false, relatedLinks, siblings },
    });
  }

  // Section index pages
  // Build meta map: slug -> { date, order } for date/order-based sorting in section views
  const entryMeta = new Map<string, { date?: string; order?: number }>();
  for (const entry of allEntries) {
    const slug = entry.id.replace(/\.md$/, '');
    const data = entry.data as any;
    entryMeta.set(slug, {
      date: data?.date ?? undefined,
      order: data?.order ?? undefined,
    });
  }

  const sections: Record<string, string[]> = {};
  for (const entry of allEntries) {
    const slug = entry.id.replace(/\.md$/, '');
    const parts = slug.split('/');
    const section = parts[0];
    if (!sections[section]) sections[section] = [];
    sections[section].push(slug);
  }

  for (const [section, files] of Object.entries(sections)) {
    paths.push({
      params: { slug: section },
      props: { entry: null, title: section, section, parts: [section], isSection: true, sectionFiles: files, entryMeta: Object.fromEntries(entryMeta), relatedLinks: [], siblings: [] },
    });
  }

  // Generate index pages for all intermediate sub-directories (enables breadcrumb links)
  const dirToFiles = new Map<string, string[]>();
  for (const entry of allEntries) {
    const slug = entry.id.replace(/\.md$/, '');
    const parts = slug.split('/');
    for (let i = 1; i < parts.length; i++) {
      const dirPath = parts.slice(0, i).join('/');
      if (!dirToFiles.has(dirPath)) dirToFiles.set(dirPath, []);
      dirToFiles.get(dirPath)!.push(slug);
    }
  }
  for (const [dirPath, files] of dirToFiles) {
    const dirParts = dirPath.split('/');
    if (dirParts.length === 1) continue; // top-level sections already handled
    const section = dirParts[0];
    const title = dirParts[dirParts.length - 1];
    paths.push({
      params: { slug: dirPath },
      props: { entry: null, title, section, parts: dirParts, isSection: true, sectionFiles: files, entryMeta: Object.fromEntries(entryMeta), relatedLinks: [], siblings: [] },
    });
  }

  return paths;
}

const { entry, title, section, parts, isSection, sectionFiles, entryMeta, relatedLinks, siblings } = Astro.props;
const meta: Record<string, { date?: string; order?: number }> = entryMeta ?? {};
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

let Content: any = null;
if (entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

// Build breadcrumb
const breadcrumb = parts.map((part: string, i: number) => ({
  label: formatFileName(decodeURIComponent(part)),
  href: base + '/wiki/' + parts.slice(0, i + 1).map((p: string) => encodeURIComponent(p)).join('/'),
  isLast: i === parts.length - 1,
}));

// Sort comparator: session numbers sort numerically; entries with date/order frontmatter sort by those; fall back to locale compare
function sessionAwareSort(a: string, b: string): number {
  const getName = (fp: string) => fp.split('/').pop() || fp;
  const getSessionNum = (fp: string): number => {
    const name = getName(fp);
    // Matches "Session -10_ ...", "Session -10.md", "Session_ -10_", etc.
    const m = name.match(/[Ss]ession[_ ]*-(\d+(?:\.\d+)?)/);
    return m ? parseFloat(m[1]) : Infinity;
  };
  const na = getSessionNum(a);
  const nb = getSessionNum(b);
  if (na !== nb) return na - nb;
  return getName(a).localeCompare(getName(b));
}

// Sort comparator for stories: order field first, then date field, then full path locale compare
// Full path compare (rather than filename-only) preserves sub-collection order, e.g.
//   "Stories/Tales from the New World/A Dream of Peace - Dawn/..." sorts before
//   "Stories/Tales from the New World/Ashes to Ashes - .../..."
function storySort(metaMap: Record<string, { date?: string; order?: number }>) {
  return function(a: string, b: string): number {
    const ma = metaMap[a] ?? {};
    const mb = metaMap[b] ?? {};
    // order field (integer) takes priority
    if (ma.order !== undefined && mb.order !== undefined) return ma.order - mb.order;
    if (ma.order !== undefined) return -1;
    if (mb.order !== undefined) return 1;
    // date field (string ISO date) as secondary
    if (ma.date && mb.date) return ma.date.localeCompare(mb.date);
    if (ma.date) return -1;
    if (mb.date) return 1;
    // fall back to full-path alphabetical (preserves sub-collection ordering)
    return a.localeCompare(b);
  };
}

// Known group ordering for the Stories section (campaign chronology)
const STORIES_GROUP_ORDER: Record<string, number> = {
  'Tales from the Eclipse': 1,
  'Tales from the New World': 2,
  'Epilogues': 3,
  'Vallyn Written Universe': 4,
};

function groupSort(section: string) {
  return function([groupA]: [string, unknown], [groupB]: [string, unknown]): number {
    if (section === 'Stories') {
      const orderA = STORIES_GROUP_ORDER[groupA] ?? 99;
      const orderB = STORIES_GROUP_ORDER[groupB] ?? 99;
      if (orderA !== orderB) return orderA - orderB;
    }
    return groupA.localeCompare(groupB);
  };
}

// Group section files by sub-folder
let groupedFiles: Record<string, string[]> = {};
if (isSection && sectionFiles) {
  const basePath = parts.join('/') + '/';
  for (const fp of sectionFiles as string[]) {
    const rest = fp.startsWith(basePath) ? fp.slice(basePath.length) : fp.replace(section + '/', '');
    const subParts = rest.split('/');
    const group = subParts.length > 1 ? subParts[0] : '_root';
    if (!groupedFiles[group]) groupedFiles[group] = [];
    groupedFiles[group].push(fp);
  }
}
---
<WikiLayout title={formatFileName(title)} section={isSection ? '' : section}>

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-1 text-sm text-parchment-500 mb-6 flex-wrap">
    <a href={base} class="hover:text-parchment-700 hover:underline">Home</a>
    {breadcrumb.map((crumb: {label: string; href: string; isLast: boolean}) => (
      <>
        <span class="mx-1 text-parchment-300">/</span>
        {crumb.isLast
          ? <span class="text-parchment-800 font-medium">{crumb.label}</span>
          : <a href={crumb.href} class="hover:text-parchment-700 hover:underline">{crumb.label}</a>
        }
      </>
    ))}
  </nav>

  {isSection ? (
    <div>
      <h1 class="font-serif text-4xl font-bold text-parchment-800 mb-8">{formatFileName(title)}</h1>
      {Object.entries(groupedFiles).sort(groupSort(section)).map(([group, files]) => (
        <div class="mb-8">
          {group !== '_root' && (
            <h2 class="font-serif text-xl font-bold text-parchment-700 mb-3 border-b border-parchment-200 pb-2">
              <a href={base + '/wiki/' + [...parts, group].map((p: string) => encodeURIComponent(p)).join('/')} class="hover:underline">{group}</a>
            </h2>
          )}
          <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
            {(files as string[]).sort(section === 'Stories' ? storySort(meta) : sessionAwareSort).map((fp: string) => {
              const rawName = fp.split('/').pop() || fp;
              const displayName = formatFileName(rawName);
              const href = base + '/wiki/' + fp.split('/').map((p: string) => encodeURIComponent(p)).join('/');
              return (
                <li>
                  <a href={href} class="block px-3 py-2 rounded-lg hover:bg-parchment-100 text-parchment-700 hover:text-parchment-900 transition-colors text-sm">
                    {displayName}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>
  ) : (
    <article data-pagefind-body>
      <h1 class="font-serif text-4xl font-bold text-parchment-800 mb-6" data-pagefind-meta="title">{formatFileName(title)}</h1>
      <div class="prose prose-lg max-w-none prose-headings:font-serif prose-a:text-parchment-700 prose-a:no-underline hover:prose-a:underline prose-hr:border-parchment-300 [&_.wiki-missing]:text-parchment-400 [&_.wiki-missing]:italic [&_.wiki-missing]:cursor-help">
        <Content />
      </div>

      {relatedLinks && relatedLinks.length > 0 && (
        <aside class="mt-10 pt-6 border-t border-parchment-200">
          <h2 class="font-serif text-lg font-semibold text-parchment-700 mb-3">Se også</h2>
          <ul class="flex flex-wrap gap-2">
            {relatedLinks.map((link: { label: string; href: string }) => (
              <li>
                <a
                  href={base + link.href}
                  class="inline-block px-3 py-1 rounded-full bg-parchment-100 text-parchment-700 hover:bg-parchment-200 hover:text-parchment-900 text-sm transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      {siblings && siblings.length > 0 && (
        <aside class="mt-6 pt-6 border-t border-parchment-200">
          <h2 class="font-serif text-sm font-semibold text-parchment-500 uppercase tracking-wide mb-3">Andre i samme gruppe</h2>
          <ul class="flex flex-wrap gap-2">
            {siblings.map((link: { label: string; href: string }) => (
              <li>
                <a
                  href={base + link.href}
                  class="inline-block px-3 py-1 rounded-full bg-parchment-50 border border-parchment-200 text-parchment-600 hover:bg-parchment-100 hover:text-parchment-900 text-sm transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </article>
  )}

</WikiLayout>
