---
import { getCollection } from 'astro:content';
import WikiLayout from '../layouts/WikiLayout.astro';

const allEntries = await getCollection('wiki');

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Build sub-section and file counts per top section
const sectionStats: Record<string, { count: number; subSections: string[] }> = {};
const sectionSubSectionSlugs: Record<string, Record<string, string>> = {};

for (const entry of allEntries) {
  const parts = entry.id.split('/');
  const section = parts[0];
  if (section === 'Vallyn') continue;

  if (!sectionStats[section]) {
    sectionStats[section] = { count: 0, subSections: [] };
    sectionSubSectionSlugs[section] = {};
  }
  sectionStats[section].count++;

  if (parts.length >= 2) {
    const sub = parts[1].replace(/\.md$/, '');
    if (!sectionStats[section].subSections.includes(sub)) {
      sectionStats[section].subSections.push(sub);
      sectionSubSectionSlugs[section][sub] =
        `${base}/wiki/${encodeURIComponent(section)}/${encodeURIComponent(sub)}`;
    }
  }
}

const sectionList = Object.entries(sectionStats).sort((a, b) => b[1].count - a[1].count);
const totalPages = allEntries.length;

// Campaign metadata
const campaigns = [
  {
    key: 'Chains of the Ancients',
    tag: 'Campaign I',
    title: 'Chains of the Ancients',
    tagline: 'A continent fractured. An empire\'s ghost.\nA war that will decide everything.',
    description: 'The Ridian Empire has fallen. In its wake, three powers rise to claim what remains. A party of soldiers, criminals, and celestials must navigate the siege of Isandor — and a darkness older than the war itself.',
    accent: 'chains',
    accentColor: '#9b2626',
    accentGlow: 'rgba(155, 38, 38, 0.12)',
  },
  {
    key: 'Dream of Dawn',
    tag: 'Campaign II',
    title: 'Dream of Dawn',
    tagline: 'An empire in myth. A brother in shadow.\nA truth buried in light.',
    description: 'In the golden city of Aurastis, the history of Regnum Aurelia is written in marble and myth. But something stirs beneath the surface — in ancient scrolls, in spellscars, and in the space between what the empire teaches and what actually happened.',
    accent: 'dawn',
    accentColor: '#c9a227',
    accentGlow: 'rgba(201, 162, 39, 0.10)',
  },
];
---
<WikiLayout title="Vallyn Wiki" description="The living wiki of the world of Vallyn — characters, lore, stories and more.">

  <!-- Hero Section (Catalyst-style) -->
  <section class="relative -mx-6 -mt-10 mb-20 flex flex-col items-center justify-center text-center px-6 py-28"
       style="background: linear-gradient(160deg, rgba(10,10,15,0.98) 0%, rgba(17,17,24,0.95) 50%, rgba(10,10,15,0.98) 100%);">
    <div class="absolute inset-0 pointer-events-none"
         style="background: radial-gradient(ellipse 60% 50% at 50% 30%, rgba(200,230,0,0.04) 0%, transparent 70%);"></div>

    <!-- Badge (Catalyst pattern) -->
    <div class="reveal relative inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-chronicle-border bg-chronicle-surface text-xs font-medium text-chronicle-muted mb-8 tracking-[-0.01em]">
      <span class="w-1.5 h-1.5 rounded-full bg-acid animate-pulse"></span>
      {totalPages} pages &mdash; A living world
    </div>

    <h1 class="reveal relative font-serif text-5xl sm:text-6xl md:text-7xl tracking-wider uppercase text-chronicle-text mb-4"
        style="text-shadow: 0 2px 30px rgba(0,0,0,0.5);">
      The <span class="text-acid">Chronicles</span>
    </h1>

    <div class="w-20 h-px mx-auto my-5" style="background: linear-gradient(to right, transparent, #C8E600, transparent);"></div>

    <p class="reveal relative text-lg text-chronicle-muted mb-10 max-w-lg tracking-[-0.01em]">
      Two worlds. Two stories. Forged at the table.
    </p>

    <div class="reveal relative flex flex-wrap justify-center gap-4 mb-16">
      <a href={`${base}/wiki/Chains%20of%20the%20Ancients`} class="btn-acid">
        Enter Campaign I
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href={`${base}/wiki/Dream%20of%20Dawn`} class="btn-ghost">Enter Campaign II</a>
    </div>

    <!-- Campaign Cards (Catalyst card system) -->
    <div class="reveal relative grid grid-cols-1 sm:grid-cols-2 gap-6 w-full max-w-[900px]">
      {campaigns.map((c) => {
        const sectionHref = `${base}/wiki/${encodeURIComponent(c.key)}`;
        return (
          <a href={sectionHref}
             class="catalyst-card group block relative p-8 text-left overflow-hidden"
             style={`border-top: 2px solid ${c.accentColor};`}>
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                 style={`background: radial-gradient(ellipse at 50% 0%, ${c.accentGlow} 0%, transparent 65%);`}>
            </div>
            <span class="relative block text-[0.65rem] tracking-[0.22em] uppercase font-semibold mb-3" style={`color: ${c.accentColor};`}>{c.tag}</span>
            <h2 class="relative font-serif text-xl sm:text-2xl font-normal text-chronicle-text mb-2 leading-tight">{c.title}</h2>
            <p class="relative font-serif italic text-sm text-chronicle-muted mb-4 leading-relaxed whitespace-pre-line">{c.tagline}</p>
            <p class="relative text-sm text-chronicle-dim mb-6 leading-relaxed">{c.description}</p>
            <span class="relative inline-flex items-center gap-1.5 text-xs font-semibold tracking-[0.08em] uppercase transition-colors duration-200 group-hover:text-acid" style={`color: ${c.accentColor};`}>
              Explore
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Metrics section (Catalyst-style stats) -->
  <section class="mb-20">
    <p class="reveal text-center text-xs tracking-[0.2em] uppercase text-chronicle-dim mb-10 font-medium">The world at a glance</p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-[900px] mx-auto">
      <div class="reveal text-center">
        <div class="text-3xl sm:text-4xl font-bold tracking-tight text-chronicle-text">{totalPages}</div>
        <p class="text-sm text-chronicle-muted mt-1">Wiki pages</p>
      </div>
      <div class="reveal text-center">
        <div class="text-3xl sm:text-4xl font-bold tracking-tight text-chronicle-text">{campaigns.length}</div>
        <p class="text-sm text-chronicle-muted mt-1">Campaigns</p>
      </div>
      <div class="reveal text-center">
        <div class="text-3xl sm:text-4xl font-bold tracking-tight text-chronicle-text">{sectionList.length}</div>
        <p class="text-sm text-chronicle-muted mt-1">Sections</p>
      </div>
      <div class="reveal text-center">
        <div class="text-3xl sm:text-4xl font-bold tracking-tight text-chronicle-text">1</div>
        <p class="text-sm text-chronicle-muted mt-1">World</p>
      </div>
    </div>
  </section>

  <!-- Content Bento Grid (Catalyst engine-style) -->
  <section class="mb-20">
    <div class="reveal text-center mb-10">
      <p class="text-xs tracking-[0.2em] uppercase text-acid font-medium mb-3">Browse</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-chronicle-text mb-2">Campaigns &amp; Content</h2>
      <p class="text-chronicle-muted text-sm max-w-md mx-auto">Explore lore, characters, session recaps, backstories, and short stories from the world of Vallyn.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sectionList.map(([section, { count, subSections }]) => {
        const sectionHref = `${base}/wiki/${encodeURIComponent(section)}`;
        const subLinks = sectionSubSectionSlugs[section] ?? {};
        const visibleSubs = subSections.slice(0, 6);
        const hiddenSubs = subSections.slice(6);
        return (
          <div class="catalyst-card group overflow-hidden reveal">
            <a href={sectionHref} class="block p-5 border-b border-chronicle-border">
              <div class="flex items-center justify-between">
                <h3 class="text-[15px] font-semibold text-chronicle-text tracking-[-0.02em] group-hover:text-acid transition-colors">{section}</h3>
                <span class="text-[11px] font-medium text-chronicle-dim bg-chronicle-raised px-2 py-0.5 rounded-full">{count}</span>
              </div>
            </a>
            {visibleSubs.length > 0 && (
              <ul class="p-4 space-y-0.5">
                {visibleSubs.map(sub => (
                  <li>
                    <a
                      href={subLinks[sub] ?? sectionHref}
                      class="block text-sm text-chronicle-muted hover:text-chronicle-text px-2.5 py-1.5 rounded-lg hover:bg-chronicle-raised transition-colors truncate"
                    >
                      {sub}
                    </a>
                  </li>
                ))}
                {hiddenSubs.length > 0 && (
                  <>
                    <li data-expand-target class="hidden">
                      {hiddenSubs.map(sub => (
                        <a
                          href={subLinks[sub] ?? sectionHref}
                          class="block text-sm text-chronicle-muted hover:text-chronicle-text px-2.5 py-1.5 rounded-lg hover:bg-chronicle-raised transition-colors truncate"
                        >
                          {sub}
                        </a>
                      ))}
                    </li>
                    <li>
                      <button
                        type="button"
                        data-expand-btn
                        class="block text-xs text-chronicle-dim hover:text-acid px-2.5 py-1.5 cursor-pointer bg-transparent border-0 transition-colors"
                      >
                        + {hiddenSubs.length} more&hellip;
                      </button>
                    </li>
                  </>
                )}
              </ul>
            )}
          </div>
        );
      })}
    </div>

    <script>
      document.querySelectorAll('[data-expand-btn]').forEach(btn => {
        btn.addEventListener('click', () => {
          const list = btn.closest('ul');
          if (!list) return;
          const target = list.querySelector('[data-expand-target]');
          if (target) target.classList.remove('hidden');
          btn.parentElement?.remove();
        });
      });
    </script>
  </section>

  <!-- CTA Banner (Catalyst-style) -->
  <section class="reveal catalyst-card p-8 sm:p-12 mb-8 text-center overflow-hidden relative">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 0%, rgba(200,230,0,0.05) 0%, transparent 70%);"></div>
    <h2 class="relative text-2xl sm:text-3xl font-bold tracking-tight text-chronicle-text mb-3">About this wiki</h2>
    <p class="relative text-chronicle-muted leading-relaxed max-w-2xl mx-auto mb-6">
      This wiki collects lore, characters, session recaps, backstories, and short stories from the New Chronicles tabletop RPG campaigns set in the world of Vallyn.
    </p>
    <div class="relative flex flex-wrap justify-center gap-3">
      <a href={`${base}/wiki/Vallyn`} class="btn-acid">
        Explore the World
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href={`${base}/wiki/People`} class="btn-ghost">Meet the Characters</a>
    </div>
  </section>

</WikiLayout>
